<table width="100%" cellpadding="0" cellspacing="0" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background-color: #f8fafc; padding: 32px 0;">
  <tr>
    <td align="center">
      <table width="560" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden;">

        <!-- Header -->
        <tr>
          <td style="background-color: #0d9488; padding: 28px 36px;">
            <p style="margin: 0; font-size: 20px; font-weight: 700; color: #ffffff; letter-spacing: -0.3px;">Points Tracker</p>
            <p style="margin: 6px 0 0; font-size: 13px; color: #99f6e4;">Weekly summary · <%= @week_label %></p>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding: 32px 36px;">
            <p style="margin: 0 0 20px; font-size: 15px; color: #1e293b;">Hi <%= @host.name %>,</p>
            <p style="margin: 0 0 28px; font-size: 14px; color: #475569; line-height: 1.6;">
              Here's how you performed last week and where you stand for the month.
            </p>

            <!-- Stats card -->
            <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #f8fafc; border-radius: 12px; border: 1px solid #e2e8f0; margin-bottom: 24px;">
              <tr>
                <td style="padding: 20px 24px;">
                  <table width="100%" cellpadding="0" cellspacing="0">
                    <tr>
                      <td style="padding-bottom: 12px;">
                        <p style="margin: 0; font-size: 11px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.6px;">Coins Last Week</p>
                        <p style="margin: 4px 0 0; font-size: 22px; font-weight: 700; color: #0d9488;"><%= number_with_delimiter(@coins_last_week) %></p>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding-bottom: 12px; border-top: 1px solid #e2e8f0; padding-top: 12px;">
                        <p style="margin: 0; font-size: 11px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.6px;">Monthly Total</p>
                        <p style="margin: 4px 0 0; font-size: 16px; font-weight: 700; color: #1e293b;"><%= number_with_delimiter(@monthly_total) %> <span style="font-size: 12px; font-weight: 400; color: #64748b;">/ <%= number_with_delimiter(@monthly_quota) %> quota</span></p>
                      </td>
                    </tr>
                    <tr>
                      <td style="padding-bottom: 12px; border-top: 1px solid #e2e8f0; padding-top: 12px;">
                        <p style="margin: 0; font-size: 11px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.6px;">Quota Progress</p>
                        <p style="margin: 4px 0 0; font-size: 16px; font-weight: 700; color: #1e293b;"><%= @quota_progress %>%</p>
                      </td>
                    </tr>
                    <tr>
                      <td style="border-top: 1px solid #e2e8f0; padding-top: 12px;">
                        <p style="margin: 0; font-size: 11px; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.6px;">Leaderboard Rank</p>
                        <p style="margin: 4px 0 0; font-size: 16px; font-weight: 700; color: #1e293b;">#<%= @rank %> <span style="font-size: 12px; font-weight: 400; color: #64748b;">of <%= @total_hosts %></span></p>
                      </td>
                    </tr>
                  </table>
                </td>
              </tr>
            </table>

            <!-- CTA -->
            <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
              <tr>
                <td align="center">
                  <a href="<%= ENV.fetch('APP_HOST', 'http://localhost:3000') %>/host" style="display: inline-block; background-color: #0d9488; color: #ffffff; font-size: 14px; font-weight: 600; text-decoration: none; padding: 12px 28px; border-radius: 8px;">View My Dashboard</a>
                </td>
              </tr>
            </table>

            <p style="margin: 0; font-size: 13px; color: #64748b; line-height: 1.6;">
              Keep it up! Every session brings you closer to your monthly quota.
            </p>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="padding: 20px 36px; border-top: 1px solid #e2e8f0; background-color: #f8fafc;">
            <p style="margin: 0; font-size: 12px; color: #94a3b8; line-height: 1.6;">
              You're receiving this weekly summary because you're a host on Points Tracker.<br>
              To opt out, turn off email notifications in your profile settings.
            </p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
