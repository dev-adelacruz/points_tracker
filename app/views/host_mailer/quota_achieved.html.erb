<table width="100%" cellpadding="0" cellspacing="0" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background-color: #f8fafc; padding: 32px 0;">
  <tr>
    <td align="center">
      <table width="560" cellpadding="0" cellspacing="0" style="background-color: #ffffff; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden;">

        <!-- Header -->
        <tr>
          <td style="background-color: #0d9488; padding: 28px 36px; text-align: center;">
            <p style="margin: 0; font-size: 36px;">🎉</p>
            <p style="margin: 8px 0 0; font-size: 20px; font-weight: 700; color: #ffffff; letter-spacing: -0.3px;">Quota Achieved!</p>
            <p style="margin: 6px 0 0; font-size: 13px; color: #99f6e4;"><%= @month_label %></p>
          </td>
        </tr>

        <!-- Body -->
        <tr>
          <td style="padding: 32px 36px; text-align: center;">
            <p style="margin: 0 0 12px; font-size: 15px; color: #1e293b;">Hi <%= @host.name %>,</p>
            <p style="margin: 0 0 28px; font-size: 14px; color: #475569; line-height: 1.6;">
              You've hit your monthly coin quota of <strong><%= number_with_delimiter(@quota) %> coins</strong>. That's a huge achievement — congratulations!
            </p>
            <table cellpadding="0" cellspacing="0" style="margin: 0 auto 24px;">
              <tr>
                <td style="background-color: #f0fdf9; border: 1px solid #99f6e4; border-radius: 12px; padding: 16px 32px; text-align: center;">
                  <p style="margin: 0; font-size: 11px; font-weight: 600; color: #0d9488; text-transform: uppercase; letter-spacing: 0.6px;">Monthly Quota</p>
                  <p style="margin: 6px 0 0; font-size: 28px; font-weight: 800; color: #0d9488;"><%= number_with_delimiter(@quota) %></p>
                  <p style="margin: 2px 0 0; font-size: 12px; color: #14b8a6;">coins ✓</p>
                </td>
              </tr>
            </table>
            <p style="margin: 0; font-size: 13px; color: #64748b; line-height: 1.6;">
              Log in to see your leaderboard ranking and keep the momentum going!
            </p>
          </td>
        </tr>

        <!-- Footer -->
        <tr>
          <td style="padding: 20px 36px; border-top: 1px solid #e2e8f0; background-color: #f8fafc;">
            <p style="margin: 0; font-size: 12px; color: #94a3b8; line-height: 1.6;">
              You're receiving this because you hit your monthly coin quota on Points Tracker.
            </p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>
